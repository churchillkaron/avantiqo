      "flow_step_14": "Case Study",
      "flow_step_15": "Marketing",
      "flow_step_16": "Next Project",
      "difference_1_title": "Not Project Management Software",
      "difference_1_text": "Project management tools manage tasks. Construction companies need to manage entire businesses.",
      "difference_2_title": "Not Traditional ERP",
      "difference_2_text": "Traditional ERP systems were built around accounting. Avantiqo is built around operational reality.",
      "difference_3_title": "Digital Twin Of Your Business",
      "difference_3_text": "Every project, supplier, worker, asset and transaction becomes part of one connected operational model.",
      "difference_4_title": "One Platform Instead Of Five",
      "difference_4_text": "Replace disconnected project software, CRM, ERP, reporting and marketing tools with one connected environment.",
