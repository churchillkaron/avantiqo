      "feature_6_text": "Project owners and executives see live progress, costs, approvals and risks from anywhere.",
      "why_title": "Why Construction Companies Choose Avantiqo",
      "why_1_title": "Project Intelligence",
      "why_1_text": "See every project, milestone, budget, delay, approval and risk from one operational runtime.",
      "why_2_title": "Contractor Accountability",
      "why_2_text": "Track subcontractors, attendance, progress, photos and task completion with evidence.",
      "why_3_title": "Cost Intelligence",
      "why_3_text": "Connect procurement, labor, inventory and project spend to understand real profitability.",
      "why_4_title": "Executive Visibility",
      "why_4_text": "Owners and executives can monitor every site without waiting for weekly reports.",
      "portal_title": "Client & Contractor Portals",
      "portal_client_title": "Client Portal",
      "portal_client_text": "Clients can follow progress, approvals, milestones, photos, invoices and project status in real time.",
      "portal_contractor_title": "Contractor Portal",
      "portal_contractor_text": "Subcontractors can submit updates, attendance, photos, documents and completion evidence directly from site.",
      "si_title": "Synthetic Intelligence",
      "si_1_title": "Predict Delays",
      "si_1_text": "Identify schedule risks before they impact project delivery.",
      "si_2_title": "Predict Budget Overruns",
      "si_2_text": "Detect procurement, labor and change-order risks before they become financial problems.",
      "si_3_title": "Automatic Progress Reports",
      "si_3_text": "Generate owner-ready project summaries automatically from site activity.",
      "si_4_title": "Procurement Intelligence",
      "si_4_text": "Recommend purchasing actions based on inventory, project schedules and supplier performance.",
      "marketing_title": "Marketing & Tender Intelligence",
      "marketing_text": "Generate company profiles, capability statements, tender documents, project case studies, social media posts and marketing campaigns directly from completed projects.",
      "challenge_title": "Construction Companies Are Losing Money Every Day",
      "challenge_text": "Most construction companies do not lose money because they lack projects. They lose money because they lack visibility. Delays, procurement mistakes, subcontractor issues, budget overruns and communication failures often remain hidden until they have already damaged profitability. Avantiqo gives management real-time visibility across projects, people, suppliers, budgets and execution so problems can be solved before they become losses.",
      "profitability_title": "Know Which Projects Actually Make Money",
      "profitability_text": "Revenue is not profit. Most construction companies can tell you project revenue, but very few can accurately explain project profitability. Avantiqo connects quotations, budgets, procurement, inventory, labor, subcontractors, equipment costs and invoices into one financial model so management can see exactly where profit is generated and where margins are disappearing.",
      "flow_title": "From Lead To Completed Project",
      "flow_text": "Construction companies often operate with disconnected systems. Sales uses one platform, project teams use another, procurement uses spreadsheets and accounting operates separately. Avantiqo connects the entire lifecycle from lead generation and quotations to project completion, billing, case studies and marketing, creating a single operational runtime for the entire company.",
      "workforce_title": "Workforce, Payroll & Site Operations",
      "workforce_text": "Managing hundreds of workers, supervisors and subcontractors across multiple sites is one of the biggest challenges in construction. Avantiqo provides workforce visibility, attendance tracking, payroll management, productivity monitoring, contractor oversight and operational reporting from one connected platform.",
      "procurement_title": "Procurement, Inventory & Equipment Control",
      "procurement_text": "Materials, equipment and procurement represent some of the largest project costs. Avantiqo connects purchase requests, supplier management, inventory, warehouses, equipment tracking and project allocations into one procurement engine. Every material movement becomes visible and every purchase becomes traceable.",
      "difference_title": "Why Avantiqo Is Different",
      "difference_text": "Most software solves one problem. Project management software manages tasks. ERP systems manage accounting. CRM systems manage customers. Avantiqo connects the entire construction business. Projects, procurement, workforce, finance, clients, marketing and synthetic intelligence operate from one environment instead of ten disconnected systems.",
      "future_title": "The Future Construction Company",
      "future_text": "The future construction company operates with live visibility, connected workflows and predictive intelligence. Instead of reacting to delays, budget overruns and operational surprises, management can make informed decisions before problems occur. Avantiqo transforms construction companies from reactive organizations into proactive businesses.",
      "cta_title": "Construction Without Blind Spots",
      "cta_text": "Connect projects, procurement, workforce, finance, reporting, client visibility, marketing and synthetic intelligence into one construction operating system.",
      "flow_step_1": "Lead",
      "flow_step_2": "CRM",
      "flow_step_3": "Quotation",
      "flow_step_4": "Tender",
      "flow_step_5": "Project Award",
      "flow_step_6": "Project Setup",
      "flow_step_7": "Procurement",
      "flow_step_8": "Inventory",
      "flow_step_9": "Workforce",
      "flow_step_10": "Site Reporting",
      "flow_step_11": "Billing",
      "flow_step_12": "Invoices",
      "flow_step_13": "Project Completion",
      "flow_step_14": "Case Study",
      "flow_step_15": "Marketing",
      "flow_step_16": "Next Project",
      "difference_1_title": "Not Project Management Software",
      "difference_1_text": "Project management tools manage tasks. Construction companies need to manage entire businesses.",
      "difference_2_title": "Not Traditional ERP",
      "difference_2_text": "Traditional ERP systems were built around accounting. Avantiqo is built around operational reality.",
      "difference_3_title": "Digital Twin Of Your Business",
      "difference_3_text": "Every project, supplier, worker, asset and transaction becomes part of one connected operational model.",
      "difference_4_title": "One Platform Instead Of Five",
      "difference_4_text": "Replace disconnected project software, CRM, ERP, reporting and marketing tools with one connected environment.",
      "marketing_item_1": "Company profiles",
      "marketing_item_2": "Capability statements",
      "marketing_item_3": "Tender documents",
      "marketing_item_4": "Project case studies",
      "marketing_item_5": "Website content",
      "marketing_item_6": "Social media campaigns",
      "marketing_item_7": "Client presentations"
    },
